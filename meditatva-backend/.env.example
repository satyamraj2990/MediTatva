# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/meditatva

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (for future auth)
JWT_SECRET=your-secret-key-change-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# Twilio Configuration (for AI Saarthi voice calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Gemini AI API Key (for AI responses)
GEMINI_API_KEY=your_gemini_api_key

# Hugging Face (for Mood Analyzer face + voice inference)
HUGGINGFACE_API_KEY=your_huggingface_api_token
HF_FACE_MODEL=trpakov/vit-face-expression
HF_VOICE_MODEL=ehcalabres/wav2vec2-lg-xlsr-en-speech-emotion-recognition
# Optional: comma-separated fallbacks if a model returns 410/503
HF_FACE_MODELS=dima806/facial_emotions_image_detection,trpakov/vit-face-expression
HF_VOICE_MODELS=superb/wav2vec2-base-superb-er,ehcalabres/wav2vec2-lg-xlsr-en-speech-emotion-recognition
# Keep false unless your token explicitly supports Hugging Face Inference Providers.
HF_ENABLE_ROUTER=false
# Timeout per Hugging Face request in milliseconds.
HF_REQUEST_TIMEOUT_MS=45000
